# Deep worker (auth, pagination, forms)
DEEP_MAX_PAGES_PER_JOB=50

# Dark worker (Tor — disabled by default for safety)
DARK_ENABLED=false
TOR_PROXY_URL=socks5://tor:9050
DARK_ALLOWED_DOMAINS=

# Worker Kafka topics (shared across team — do not rename without team agreement)
CRAWL_REQUEST_TOPIC=crawl.requests
CRAWL_RAW_TOPIC=crawl.raw
